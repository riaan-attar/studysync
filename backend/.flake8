[flake8]
max-line-length = 120

ignore =
    E201,
    E202,
    E124,
    E226,
    E231,
    E305,
    E401,
    E701,
    E712,
    E117,
    E127,
    E116,
    E111,
    E501,
    W291,
    W293,
    W292,
    W391,
    E302,
    E261,
    F401,
    F541,
    F811

exclude =
    .git,
    __pycache__,
    migrations,
    tests