# In backend/.env

# Groq API Key for LLM integrations (Get from Groq Console)
GROQ_API_KEY=

# PostgreSQL Database Connection String (e.g., from Supabase Dashboard -> Project Settings -> Database)
DATABASE_URL=

# Google Gemini API Key or General Google API Key (Get from Google AI Studio or Google Cloud)
GOOGLE_API_KEY=

# Google OAuth 2.0 Client ID (Must match the frontend GOOGLE_CLIENT_ID)
GOOGLE_AUDIENCE_CLIENT_ID=

# Clist API Key for programming contest data (Get from clist.by)
CLIST_API_KEY=

# Subabase Project URL (Get from Supabase Dashboard -> Project Settings -> API)
SUPABASE_URL=

# Supabase Service Role Key (Get from Supabase Dashboard -> Project Settings -> API)
SUPABASE_SERVICE_KEY=

# Google OAuth 2.0 Client Secret (Must match the frontend GOOGLE_CLIENT_SECRET)
GOOGLE_CLIENT_SECRET=